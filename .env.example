# PostgreSQL credentials (used by both the postgres and backend services)
DB_USER=ecs_admin
DB_PASSWORD=change-me-db-password

# SQLAlchemy connection string used by the backend
DATABASE_URL=postgresql+psycopg2://ecs_admin:change-me-db-password@postgres:5432/ecs_request

# Random string used to sign/derive secrets
SECRET_KEY=change-me-to-a-long-random-string

# Key material for AES-256 encryption of AK/SK and instance passwords at rest.
# Any string works; a 32-byte key is derived from it with SHA-256.
ENCRYPTION_KEY=change-me-to-a-long-random-key

# Password for the seeded admin account (admin@system.local) on first boot
DEFAULT_ADMIN_PASSWORD=admin123
